# Database Configuration
SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/linkedin_ai
SPRING_DATASOURCE_USERNAME=root
SPRING_DATASOURCE_PASSWORD=your_db_password

# JWT Configuration (7 days = 604800000 milliseconds)
APP_JWT_SECRET=your-super-secret-key-min-256-bits-long-for-security-purposes-change-in-production-environment
APP_JWT_EXPIRATION=604800000

# LinkedIn OAuth Configuration
LINKEDIN_CLIENT_ID=your_linkedin_client_id
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret
LINKEDIN_REDIRECT_URI=http://localhost:8080/login/oauth2/code/linkedin

# Server Configuration
SERVER_PORT=8080

# Gemini API Configuration (optional)
GEMINI_API_KEY=your_gemini_api_key
